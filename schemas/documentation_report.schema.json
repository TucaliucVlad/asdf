{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocumentationReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "batch_id",
    "task_ids",
    "summary",
    "files_changed",
    "tests_run",
    "result",
    "usage_reason"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "batch_id": {
      "type": "string",
      "minLength": 1
    },
    "task_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tests_run": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "result": {
      "type": "string",
      "enum": [ "success", "partial", "failure" ]
    },
    "usage_reason": {
      "type": "string",
      "minLength": 1
    }
  }
}